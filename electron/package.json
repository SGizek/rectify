{
  "name": "rectify-electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.rectify.app",
    "productName": "Rectify",
    "directories": { "output": "dist" },
    "win": {
      "target": "nsis",
      "icon": "../public/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
